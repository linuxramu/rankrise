    {
      "name": "Tests",
      "item": [
        {
          "name": "List Tests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tests",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tests"
              ]
            },
            "description": "Get list of all tests"
          },
          "response": []
        },
        {
          "name": "Get Test",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tests/{{test_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tests",
                "{{test_id}}"
              ]
            },
            "description": "Get details of a specific test"
          },
          "response": []
        },
        {
          "name": "Create Test",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login (admin only)"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"JEE Main - Full Length Test 1\",\n  \"examId\": \"exam_jee_mains\",\n  \"type\": \"FULL_LENGTH\",\n  \"durationMinutes\": 180,\n  \"totalQuestions\": 90,\n  \"totalMarks\": 300\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tests",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tests"
              ]
            },
            "description": "Create a new test (admin only)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Results",
      "item": [
        {
          "name": "List Results",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/results",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "results"
              ]
            },
            "description": "Get user's test results"
          },
          "response": []
        },
        {
          "name": "Get Result",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/results/{{result_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "results",
                "{{result_id}}"
              ]
            },
            "description": "Get details of a specific result"
          },
          "response": []
        },
        {
          "name": "Submit Test Result",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"testId\": \"test_123\",\n  \"attemptId\": \"attempt_123\",\n  \"score\": 250,\n  \"answers\": [\n    {\n      \"questionId\": \"q1\",\n      \"answerIndex\": 2,\n      \"timeSpent\": 45\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/results",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "results"
              ]
            },
            "description": "Submit test result after completion"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Analytics",
          "request": {
            "method": "GET",
