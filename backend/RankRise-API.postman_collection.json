              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"SecurePass123\",\n  \"name\": \"John Doe\",\n  \"targetExam\": \"JEE_MAINS\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
