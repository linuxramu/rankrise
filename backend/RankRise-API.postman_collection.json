  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8787",
      "type": "string",
      "description": "Base URL - Change to https://rankrise-backend.ramuoncloud.workers.dev for production"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token from login - Copy from login response and paste here"
    },
    {
      "key": "test_id",
      "value": "",
      "type": "string",
      "description": "Test ID for specific test queries"
    },
    {
      "key": "result_id",
      "value": "",
      "type": "string",
      "description": "Result ID for specific result queries"
    }
  ]
