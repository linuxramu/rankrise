        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "JWT token from login"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/analytics/leaderboard?exam=JEE_MAINS&limit=100",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "analytics",
                "leaderboard"
              ],
              "query": [
                {
                  "key": "exam",
                  "value": "JEE_MAINS"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            },
            "description": "Get leaderboard for a specific exam"
          },
          "response": []
        }
      ]
