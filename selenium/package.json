{
  "name": "rankrise-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for RankRise using Selenium WebDriver",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest --detectOpenHandles",
    "test:debug": "jest --detectOpenHandles --verbose",
    "test:watch": "jest --detectOpenHandles --watch",
    "test:headless": "HEADLESS=true jest --detectOpenHandles",
    "test:report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "test:report:serve": "allure generate allure-results --clean -o allure-report && npx http-server allure-report -p 8080",
    "test:ci": "npm run test:headless -- --coverage",
    "allure:clean": "rm -rf allure-results allure-report"
  },
  "keywords": [
    "selenium",
    "e2e",
    "testing",
    "rankrise"
  ],
  "author": "RankRise Team",
  "license": "MIT",
  "dependencies": {
    "selenium-webdriver": "^4.22.0",
    "dotenv": "^16.3.1",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-allure": "^0.1.3",
    "allure-commandline": "^2.25.0",
    "babel-jest": "^29.7.0",
    "@babel/preset-env": "^7.23.3",
    "http-server": "^14.1.1"
  }
}
