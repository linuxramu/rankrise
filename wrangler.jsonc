{
  "name": "rankrise",
  "main": "src/worker.ts",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "cd frontend && npm install && npm run build"
  },
  "assets": {
    "directory": "frontend/dist"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "rankrise",
      "database_id": "2e7cc259-eb61-431d-8658-591e3d8d9340"
    }
  ]
}
