{
  "name": "rankrise",
  "main": "src/worker.ts",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "cd frontend && npm install && npm run build"
  },
  "assets": {
    "directory": "./frontend/dist"
  }
}
